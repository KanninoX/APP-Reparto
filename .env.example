# =============================================
# Copiar como .env y completar los valores
# NUNCA subir .env a git
# =============================================

# Base de datos PostgreSQL
DB_NAME=appreparto
DB_USER=appreparto
DB_PASSWORD=CAMBIA_ESTO_PASSWORD_SEGURA

# JWT — mínimo 64 caracteres aleatorios
JWT_SECRET=CAMBIA_ESTO_POR_SECRET_64_CHARS_MIN_EJEMPLO_abc123XYZ...

# AWS
AWS_REGION=us-east-1
S3_BUCKET=app-reparto-docs
SES_FROM_EMAIL=noreply@appreparto.cl

# CORS — IP pública o dominio del EC2 (sin barra final)
CORS_ORIGINS=http://TU_IP_EC2_PUBLICA
